{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lynse",
  "version": "0.1.0",
  "identifier": "app.lynse.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @lynse/tauri exec vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm --filter @lynse/tauri exec vite build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lynse",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 16, "y": 13 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "resources": {
      "resources/funasr_transcribe.py": "funasr_transcribe.py"
    }
  }
}
