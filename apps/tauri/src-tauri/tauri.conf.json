{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lynse",
  "version": "0.1.13",
  "identifier": "app.lynse.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @lynse/tauri build:audio-capture && pnpm --filter @lynse/tauri exec vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm --filter @lynse/tauri build:audio-capture && pnpm --filter @lynse/tauri exec vite build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": " ",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 16, "y": 28 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/funasr_transcribe.py": "funasr_transcribe.py",
      "resources/sidecars/whisper": "whisper",
      "resources/sidecars/whisper.exe": "whisper.exe",
      "resources/sidecars/moss-transcribe": "moss-transcribe",
      "resources/sidecars/moss-transcribe.exe": "moss-transcribe.exe",
      "resources/sidecars/ffmpeg": "ffmpeg",
      "resources/sidecars/ffmpeg.exe": "ffmpeg.exe",
      "resources/sidecars/ffprobe": "ffprobe",
      "resources/sidecars/ffprobe.exe": "ffprobe.exe",
      "resources/sidecars/audio-capture": "audio-capture"
    },
    "macOS": {
      "minimumSystemVersion": "15.0"
    }
  }
}
