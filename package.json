{
  "name": "lynse-webapp",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "turbo dev --filter=@lynse/web",
    "dev:desktop": "turbo dev --filter=@lynse/tauri",
    "dev:tauri": "turbo dev --filter=@lynse/tauri",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "ui:add": "cd packages/ui && npx shadcn@latest add"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:"
    }
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "catalog:"
  },
  "dependencies": {
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.8.0"
  }
}
